ENVIRONMENT=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://sql_analyst:sql_analyst@localhost:5432/sql_analyst
SYNC_DATABASE_URL=postgresql+psycopg2://sql_analyst:sql_analyst@localhost:5432/sql_analyst

LLM_PROVIDER=fake

# --- Gemini (recommended: free tier, no credit card, no GCP project) ---
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic (alternative, paid) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

VECTOR_DB_PATH=./chroma_db

JWT_SECRET_KEY=change-me-in-production

API_BASE_URL=http://localhost:8000/api/v1

# --- Advanced / optional tuning (sensible defaults already in backend/config.py) ---
# APP_NAME=AI SQL Analyst
# API_V1_PREFIX=/api/v1
# LLM_MAX_RETRIES=2
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# SQL_REPAIR_MAX_ATTEMPTS=2
# MAX_RESULT_ROWS=1000
